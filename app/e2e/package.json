{
  "name": "pyops-e2e",
  "private": true,
  "description": "Standalone Playwright E2E suite for the PyOps app (isolated from the app's pnpm/nightly toolchain).",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0"
  }
}

{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        { "type": "json", "path": "app/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "app/src-tauri/tauri.conf.json", "jsonpath": "$.version" },
        { "type": "toml", "path": "app/src-tauri/Cargo.toml", "jsonpath": "$.package.version" },
        { "type": "json", "path": "mod/info.json", "jsonpath": "$.version" }
      ]
    }
  }
}
